{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontoffice-offseason-agent/schemas/roster_memberships_schema.json",
  "title": "Roster Memberships Schema (M10-E4)",
  "description": "Schema for normalized/roster_memberships.json in curated real NBA snapshots. Defines player-to-team roster membership metadata only: team_id, player_id, roster_status, and provenance. Must NOT contain salary/contract/cap data, injury/medical status, social media, agent representation, rumors, scouting opinions, live/availability data, depth-chart/minutes/role/rotation projections, trade eligibility/restrictions, starter/bench labels, availability status, logos, or execution/live/current/latest fields. Inactive/waived/traded/injured/suspended/availability statuses are FORBIDDEN in M10-E (see roster_status enum). This is a schema-only artifact in M10-E4; no real roster data is added in this milestone.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_id",
    "as_of_date",
    "manual_review_required",
    "live_eligible",
    "data_freshness_warning",
    "limitations",
    "source_name",
    "source_type",
    "roster_memberships"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Schema version identifier, e.g. m10-e4-v1"
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9_-]+$",
      "description": "Snapshot identifier this file belongs to, e.g. nba_real_2026_preoffseason_v1"
    },
    "as_of_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Data cutoff date in YYYY-MM-DD format"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1,
      "description": "ISO 8601 timestamp when this file was generated (optional)"
    },
    "source_name": {
      "type": "string",
      "minLength": 1,
      "description": "Primary source name for roster memberships"
    },
    "source_url": {
      "type": ["string", "null"],
      "description": "Source URL, or null if no direct public URL is appropriate"
    },
    "source_type": {
      "type": "string",
      "enum": ["manual_curated", "public_reference", "league_public_reference", "team_public_reference", "manual_review"],
      "description": "Provenance classification. llm_generated / scraped_unreviewed / live_api are forbidden."
    },
    "manual_review_required": {
      "type": "boolean",
      "const": true,
      "description": "All curated real roster membership data requires manual review"
    },
    "live_eligible": {
      "type": "boolean",
      "const": false,
      "description": "Roster memberships are frozen as-of metadata; never live/current"
    },
    "data_freshness_warning": {
      "type": "string",
      "minLength": 1,
      "description": "UI-mandatory freshness warning (not live, membership-only; does not reflect subsequent trades/signings)."
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "Limitations/caveats (e.g. membership only, no contract, no availability, not live)."
    },
    "roster_memberships": {
      "type": "array",
      "items": { "$ref": "#/$defs/membership" },
      "description": "Roster membership records"
    }
  },
  "$defs": {
    "membership": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "team_id",
        "player_id",
        "roster_status",
        "source_name",
        "source_type",
        "as_of_date",
        "manual_review_required",
        "live_eligible",
        "data_freshness_warning",
        "snapshot_id",
        "limitations"
      ],
      "properties": {
        "membership_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Optional stable membership identifier (lowercase letters, digits, dash, underscore)."
        },
        "team_id": {
          "type": "string",
          "pattern": "^nba-[A-Z]{3}$",
          "description": "Team ID in nba-XXX format matching teams.json (e.g. nba-ATL, nba-GSW)."
        },
        "player_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Stable player identifier matching player_identities.json (lowercase letters, digits, dash, underscore). Synthetic tests may use player-test-alpha / p-syn-alpha."
        },
        "roster_status": {
          "type": "string",
          "enum": ["standard", "two_way", "training_camp", "unsigned_draft_rights", "free_agent", "unknown_manual_review"],
          "description": "Safe, non-live roster status category. Inactive/waived/traded/injured/suspended/questionable/probable/day_to_day/available/unavailable/active_now/latest/current are FORBIDDEN in M10-E because they imply live roster, injury, transaction, or availability semantics deferred to M10-F+."
        },
        "source_name": {
          "type": "string",
          "minLength": 1,
          "description": "Per-record source name."
        },
        "source_url": {
          "type": ["string", "null"],
          "description": "Per-record source URL or null."
        },
        "source_type": {
          "type": "string",
          "enum": ["manual_curated", "public_reference", "league_public_reference", "team_public_reference", "manual_review"],
          "description": "Per-record provenance classification."
        },
        "as_of_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
          "description": "Record-level cutoff date."
        },
        "manual_review_required": {
          "type": "boolean",
          "const": true
        },
        "data_freshness_warning": {
          "type": "string",
          "minLength": 1,
          "description": "Per-record freshness warning."
        },
        "live_eligible": {
          "type": "boolean",
          "const": false
        },
        "snapshot_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9_-]+$",
          "description": "Must match the top-level snapshot_id."
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Optional curator notes (disambiguation, caveats)."
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "description": "Per-record limitations (membership-only, no contract, no availability, not live, etc.)."
        }
      },
      "propertyNames": {
        "not": {
          "enum": [
            "salary", "salaries", "contract", "contracts", "cap_hold", "guarantee",
            "guarantee_amount", "cap_sheet", "cap_sheets",
            "injury", "injuries", "injury_status", "medical", "medical_status", "health",
            "trade_eligibility", "trade_restriction", "no_trade_clause",
            "availability", "real_time_availability", "live_status", "current_status",
            "latest_status", "active_now",
            "projected_depth_chart", "depth_chart", "minutes_projection", "role_projection",
            "starter", "bench_role", "rotation_role",
            "scouting_opinion", "scouting_opinions", "rumors", "rumor",
            "agent", "agent_representation", "social_media", "personal_sensitive_info",
            "headshot", "headshot_url", "player_image", "photo_url", "official_headshot",
            "execute", "apply", "commit", "mutate", "write", "persist", "save",
            "delete", "update", "submit", "auto_execute", "auto_approve",
            "inactive", "waived", "traded", "suspended", "questionable", "probable",
            "day_to_day", "available", "unavailable", "current_roster", "latest_roster",
            "live_salaries", "latest_data", "live_data", "current_salaries", "real_time_data",
            "current", "latest",
            "logo_path", "logo_url", "official_logo", "nba_logo", "team_logo", "mascot_image"
          ]
        },
        "description": "Forbidden per-membership fields: money/contract, medical/injury, trade restrictions, availability/live status, depth/role/rotation projections, starter/bench labels, opinion/rumors, PII/social/agent, photos, execution verbs, inactive/waived/traded/injured/suspended/availability statuses, current/latest naming, logos."
      }
    }
  },
  "propertyNames": {
    "not": {
      "enum": [
        "salary", "salaries", "contract", "contracts", "cap_hold", "guarantee",
        "guarantee_amount", "cap_sheet", "cap_sheets",
        "injury", "injuries", "injury_status", "medical", "medical_status", "health",
        "trade_eligibility", "trade_restriction", "no_trade_clause",
        "availability", "real_time_availability", "live_status", "current_status",
        "latest_status", "active_now",
        "projected_depth_chart", "depth_chart", "minutes_projection", "role_projection",
        "starter", "bench_role", "rotation_role",
        "scouting_opinion", "scouting_opinions", "rumors", "rumor",
        "agent", "agent_representation", "social_media", "personal_sensitive_info",
        "headshot", "headshot_url", "player_image", "photo_url", "official_headshot",
        "execute", "apply", "commit", "mutate", "write", "persist", "save",
        "delete", "update", "submit", "auto_execute", "auto_approve",
        "inactive", "waived", "traded", "suspended", "questionable", "probable",
        "day_to_day", "available", "unavailable", "current_roster", "latest_roster",
        "live_salaries", "latest_data", "live_data", "current_salaries", "real_time_data",
        "current", "latest",
        "logo_path", "logo_url", "official_logo", "nba_logo", "team_logo", "mascot_image"
      ]
    },
    "description": "Forbidden top-level fields for roster_memberships.json."
  }
}
